# Setup new xdg for armbian
if [ -d /etc/xdg ]; then 
cp -rv /etc/xdg /etc/xdg-armbian;
fi

#set new xfce pre-cconfig dir
if [ -f /etc/environment ]; then cat <<EOF > /etc/environment
#
# This file is parsed by pam_env module
# Syntax: simple "KEY=VAL" pairs on separate lines
#
XDG_CONFIG_DIRS="/etc/xdg-armbian"
EOF
fi

#set desktop theme/color defauts via xdg-armbian
if [ -f /etc/xdg-armbian/xfce4/xfconf/xfce-perchannel-xml/xsettings.xml ]; then 
sed -i 's|^    <property name="ThemeName" type="string" value="Xfce"/>|    <property name="ThemeName" type="string" value="Numix"/>|' /etc/xdg-armbian/xfce4/xfconf/xfce-perchannel-xml/xsettings.xml; 
fi

#set desktop theme/color defauts via xdg-armbian
if [ -f /etc/xdg-armbian/xfce4/xfconf/xfce-perchannel-xml/xsettings.xml ]; then 
sed -i 's|^    <property name="IconThemeName" type="string" value="Numix"/>|    <property name="IconThemeName" type="string" value="Numix"/>|' /etc/xdg-armbian/xfce4/xfconf/xfce-perchannel-xml/xsettings.xml; 
fi

#set desktop theme/color defauts via xdg-armb
if [ -f /usr/share/xfwm4/defaults ]; then 
sed -i 's|^worspace_count=4 | worspace_count=2|' /usr/share/xfwm4/defaults
fi

# Adjust menu button icon defauts via xdg-armbian
if [ -f /etc/xdg-armbian/panel/default.xml ]; then
sed -i '/<property name="plugin-1" type="string" value="applicationsmenu\/">/ {
    s/<property name="plugin-1" type="string" value="applicationsmenu\/">/<property name="plugin-1" type="string" value="applicationsmenu">/;
    a\
      <property name="button-icon" type="string" value="/usr/share/pixmaps/armbian/armbian.png"/>\
	</property>
}' /etc/xdg-armbian/xfce4/panel/default.xml
fi

# Adjust menu defauts via xdg-armbian
if [ -f /etc/xdg-armbian/menus/xfce-applications.menu ]; then
sed -i -n '/<Menuname>Settings<\/Menuname>/{p;:a;N;/<Filename>xfce4-session-logout.desktop<\/Filename>/!ba;s/.*\n/\
\t<Separator\/>\n\t<Merge type="all"\/>\n        <Separator\/>\n        <Filename>armbian-donate.desktop<\/Filename>\
\n        <Filename>armbian-support.desktop<\/Filename>\n/};p' /etc/xdg-armbian/menus/xfce-applications.menu
fi

# Hide few items from menu(only works if installed at build time)
if [ -f /usr/share/applications/display-im6.q16.desktop ]; then mv /usr/share/applications/display-im6.q16.desktop /usr/share/applications/display-im6.q16.desktop.hidden; fi
if [ -f /usr/share/applications/display-im6.desktop ]; then  mv /usr/share/applications/display-im6.desktop /usr/share/applications/display-im6.desktop.hidden; fi
if [ -f /usr/share/applications/vim.desktop ]; then  mv /usr/share/applications/vim.desktop /usr/share/applications/vim.desktop.hidden; fi
if [ -f /usr/share/applications/libreoffice-startcenter.desktop ]; then mv /usr/share/applications/libreoffice-startcenter.desktop /usr/share/applications/libreoffice-startcenter.desktop.hidden; fi
