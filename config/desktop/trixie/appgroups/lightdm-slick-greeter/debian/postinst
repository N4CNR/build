# create default sddm config
if [ -d /etc/lightdm ]; then
	mkdir -p /etc/lightdm/lightdm.conf.d
fi

cat <<- EOF > /etc/lightdm/slick-greeter.conf
	[Greeter]
	background = /usr/share/backgrounds/armbian-lightdm/armbian03-Dre0x-Minum-dark-blurred-3840x2160.jpg
	theme-name = Numix
	icon-theme-name = Numix
	font-name = Sans 11
	draw-user-background = false
	show-keyboard = true
	onscreen-keyboard = false
	screen-reader = true
	draw-grid = false
	cursor-theme-name=Awaita
	cursor-theme-size=24
EOF

cat <<- EOF > /etc/lightdm/lightdm.conf.d/10-slick-greeter.conf
	[Seat:*]
	user-session=xfce
	greeter-show-manual-login=false
	greeter-hide-users=false
	allow-guest=false
EOF

cat <<- EOF > /etc/lightdm/lightdm.conf.d/10-armbian.conf
	[Seat:*]
	user-session=xfce
	greeter-show-manual-login=false
	greeter-hide-users=false
	allow-guest=false
EOF