action.yml:        passphrase: ${{ inputs.armbian_pgp_password }}
action.yml:        repository: armbian/os
action.yml:        repository: armbian/build
action.yml:        ref: ${{ inputs.armbian_branch }}
action.yml:        [[ "${{ inputs.armbian_version }}" != '' ]] && echo "ARMBIAN_VERSION=${{ inputs.armbian_version }}" >> $GITHUB_ENV
action.yml:        if [[ "${{ inputs.armbian_ui }}" == minimal ]]; then
action.yml:        elif [[ "${{ inputs.armbian_ui }}" == server ]]; then
action.yml:          DESKTOP_ENVIRONMENT="${{ inputs.armbian_ui }}"
action.yml:        ./compile.sh "${{ inputs.armbian_target }}" \
action.yml:        BOARD="${{ inputs.armbian_board }}" \
action.yml:        BRANCH="${{ inputs.armbian_kernel_branch }}" \
action.yml:        RELEASE="${{ inputs.armbian_release }}" \
action.yml:        ENABLE_EXTENSIONS="${{ inputs.armbian_extensions }}" \
action.yml:        COMPRESS_OUTPUTIMAGE="${{ inputs.armbian_compress }}" \
action.yml:      if: ${{ inputs.armbian_pgp_password != '' }}
action.yml:        echo ${{ inputs.armbian_pgp_password }} | \
action.yml:        tag: ${{ inputs.armbian_release_tag != '' && inputs.armbian_release_tag || env.ARMBIAN_VERSION }}
action.yml:        name: "${{ inputs.armbian_release_tittle }}"
action.yml:        artifacts: "${{ inputs.armbian_artifacts }}*"
action.yml:        token: "${{ inputs.armbian_token }}"
action.yml:          ${{ inputs.armbian_release_body }}
